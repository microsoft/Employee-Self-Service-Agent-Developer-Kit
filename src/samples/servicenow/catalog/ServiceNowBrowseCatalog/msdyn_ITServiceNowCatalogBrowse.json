{
  "Scenario": "msdyn_ITServiceNowCatalogBrowse",
  "Table": "sc_cat_item",
  "Operation": "READ",
  "FilterCriteria": [
    { "FieldName": "active", "Operator": "=", "Value": "true" },
    { "FieldName": "short_description", "Operator": "LIKE", "VariableName": "SearchTerm" }
  ],
  "SortCriteria": [
    { "FieldName": "order", "Operator": "ASC" }
  ],
  "Limit": 10,
  "Offset": 0,
  "DisplaySystemReferences": true,
  "ExcludeReferenceLinks": true,
  "OutputFieldMapping": [
    { "FieldName": "name", "OutputName": "ItemName" },
    { "FieldName": "short_description", "OutputName": "Description" },
    { "FieldName": "category", "OutputName": "Category" },
    { "FieldName": "price", "OutputName": "Price" },
    { "FieldName": "sys_id", "OutputName": "ItemId" }
  ]
}
