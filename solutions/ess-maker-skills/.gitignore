# Ignore everything in workspace/ and .local/ EXCEPT the .gitkeep scaffolds
workspace/**
!workspace/
!workspace/onboarding/
!workspace/agents/
!workspace/**/.gitkeep

.local/**
!.local/
!.local/.gitkeep

# my/ holds skill-internal state (per-skill config and tasks.md). Used by
# /connect, /provision, etc. for resumable run state. Never committed.
my/**
!my/
!my/.gitkeep