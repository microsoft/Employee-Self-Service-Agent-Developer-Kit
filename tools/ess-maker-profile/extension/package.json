{
  "name": "ess-maker-profile",
  "displayName": "ESS Maker",
  "description": "Chat-only, big-button experience for customizing your Employee Self-Service agent. POC.",
  "version": "0.4.21",
  "publisher": "microsoft-ess",
  "private": true,
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "essMaker.runSetup",
        "title": "ESS Maker: Connect to environment",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.runCreate",
        "title": "ESS Maker: Create a topic",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.runFlightcheck",
        "title": "ESS Maker: Validate readiness (FlightCheck)",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.runScan",
        "title": "ESS Maker: Scan for issues",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.runPush",
        "title": "ESS Maker: Push to Copilot Studio",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.applyMakerLayout",
        "title": "ESS Maker: Apply Maker Layout",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.restoreStandardLayout",
        "title": "ESS Maker: Restore Standard Layout",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.openWalkthrough",
        "title": "ESS Maker: Open Welcome Walkthrough",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.focusActions",
        "title": "ESS Maker: Show Action Buttons",
        "category": "ESS Maker"
      },
      {
        "command": "essMaker.startChatOnly",
        "title": "ESS Maker: Start Chat-Only Layout",
        "category": "ESS Maker"
      }
    ],
    "viewsContainers": {
      "auxiliarybar": [
        {
          "id": "essMakerActions",
          "title": "ESS Maker",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "essMakerActions": [
        {
          "type": "webview",
          "id": "essMaker.actionsView",
          "name": "Quick actions",
          "contextualTitle": "ESS Maker"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "essMaker.welcome",
        "title": "Welcome to the ESS Maker Kit",
        "description": "Build, update, and publish your Employee Self-Service agent in plain English. No code required.",
        "steps": [
          {
            "id": "overview",
            "title": "Welcome",
            "description": "This kit lets you describe what your ESS agent should do, and GitHub Copilot does the rest.\n\nWork through the steps on the left in order. Each step opens a guided chat — just answer the prompts.\n\n[Close this guide](command:workbench.action.closeActiveEditor)",
            "media": {
              "markdown": "walkthrough/overview.md"
            },
            "completionEvents": []
          },
          {
            "id": "connect",
            "title": "1. Connect to your environment",
            "description": "Sign in to your Power Platform environment so the kit can read your ESS agent.\n[Connect now](command:essMaker.runSetup)",
            "media": {
              "markdown": "walkthrough/connect.md"
            },
            "completionEvents": [
              "onCommand:essMaker.runSetup"
            ]
          },
          {
            "id": "create",
            "title": "2. Create a topic",
            "description": "Describe a new conversation in plain English. The kit generates the topic, adaptive cards and integration wiring.\n[Create a topic](command:essMaker.runCreate)",
            "media": {
              "markdown": "walkthrough/create-topic.md"
            },
            "completionEvents": [
              "onCommand:essMaker.runCreate"
            ]
          },
          {
            "id": "scan",
            "title": "3. Scan for issues",
            "description": "Find broken references, missing bindings and malformed configuration before you ship.\n[Scan now](command:essMaker.runScan)",
            "media": {
              "markdown": "walkthrough/scan.md"
            },
            "completionEvents": [
              "onCommand:essMaker.runScan"
            ]
          },
          {
            "id": "flightcheck",
            "title": "4. Validate readiness",
            "description": "Run 41+ automated checks across licensing, environment, integrations and publishing readiness.\n[Run FlightCheck](command:essMaker.runFlightcheck)",
            "media": {
              "markdown": "walkthrough/flightcheck.md"
            },
            "completionEvents": [
              "onCommand:essMaker.runFlightcheck"
            ]
          },
          {
            "id": "push",
            "title": "5. Push to Copilot Studio",
            "description": "Deploy your changes safely: checkpoint → dry-run diff → push → verify. Rollback is always one command away.\n[Push to Copilot Studio](command:essMaker.runPush)",
            "media": {
              "markdown": "walkthrough/push.md"
            },
            "completionEvents": [
              "onCommand:essMaker.runPush"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "validate": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8'))\""
  }
}
