{
  "name": "ESS Maker Kit",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  // Attempts to set VS Code's active folder to the maker-kit subdirectory on launch.
  // Note: GitHub Codespaces may ignore this setting (known limitation) — users should
  // open solutions/ess-maker-skills manually via File > Open Folder if needed.
  "workspaceFolder": "/workspaces/Employee-Self-Service-Agent-Developer-Kit/solutions/ess-maker-skills",

  // postCreateCommand runs once after the container is built. It installs Python
  // dependencies from requirements.txt. If any dependency fails, the container will
  // still start but the user will see the error in the creation log.
  "postCreateCommand": "pip install --quiet --disable-pip-version-check -r /workspaces/Employee-Self-Service-Agent-Developer-Kit/solutions/ess-maker-skills/scripts/requirements.txt && echo '' && echo '=== ESS Maker Kit ready! ===' && echo 'Open File > Open Folder and select solutions/ess-maker-skills, then run /setup in Copilot Chat.' && echo ''",

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}
